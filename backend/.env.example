# PostgreSQL connection string
# Local: postgresql://postgres:password@localhost:5432/medisync
# Railway/Render: auto-provided as DATABASE_URL
DATABASE_URL="postgresql://postgres:11871142@localhost:5432/medisync"

# JWT signing secret — change this to a long random string in production
JWT_SECRET="change-me-to-a-long-random-string-in-production"

# Server port (Railway/Render inject PORT automatically)
PORT=3001

# Frontend origin for CORS (comma-separated for multiple)
# Development: http://127.0.0.1:5500
# Production: https://your-frontend-domain.com
FRONTEND_URL="http://127.0.0.1:5500,http://localhost:5500,http://localhost:3000"

# Environment
NODE_ENV="development"
